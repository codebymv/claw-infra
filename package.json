{
  "name": "claw-infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:agent": "npm --prefix agent run dev",
    "build": "concurrently \"npm run build:backend\" \"npm run build:frontend\" \"npm run build:agent\"",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "build:agent": "npm --prefix agent run build",
    "install:all": "npm --prefix backend install && npm --prefix frontend install && npm --prefix agent install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
