NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# --- Option A: Railway managed databases (recommended) ---
DATABASE_URL=postgresql://postgres:<password>@shuttle.proxy.rlwy.net:<port>/railway
REDIS_URL=redis://default:<password>@yamabiko.proxy.rlwy.net:<port>

# --- Option B: Local Docker databases ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claw_infra
# REDIS_URL=redis://localhost:6379

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Code visibility webhooks/reconciliation
CODE_WEBHOOKS_ENABLED=false
GITHUB_WEBHOOK_SECRET=
CODE_RECONCILIATION_INTERVAL_MINUTES=360

# Security — IP allowlisting
ALLOWED_IPS=
IP_ALLOWLIST_ENABLED=false
REGISTRATION_ENABLED=true

# Ingest reliability
INGEST_IDEMPOTENCY_ENABLED=false
INGEST_IDEMPOTENCY_TTL_HOURS=24

# Telegram Alerts — get from @BotFather and /getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
