NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# --- Option A: Railway managed databases (recommended) ---
DATABASE_URL=postgresql://postgres:<password>@shuttle.proxy.rlwy.net:<port>/railway
REDIS_URL=redis://default:<password>@yamabiko.proxy.rlwy.net:<port>

# --- Option B: Local Docker databases ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claw_infra
# REDIS_URL=redis://localhost:6379

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT Secret Rotation (optional)
# JWT_SECRETS=secret1,secret2,secret3  # Comma-separated list of valid secrets
# JWT_SIGNING_SECRET=secret3           # Secret to use for signing new tokens

# API Key HMAC Secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET=

# Code visibility webhooks/reconciliation
CODE_WEBHOOKS_ENABLED=false
GITHUB_WEBHOOK_SECRET=
CODE_RECONCILIATION_INTERVAL_MINUTES=360
CODE_QUALITY_HOTFIX_WINDOW_HOURS=48

# Security — IP allowlisting
ALLOWED_IPS=
IP_ALLOWLIST_ENABLED=false
REGISTRATION_ENABLED=true

# Ingest reliability
INGEST_IDEMPOTENCY_ENABLED=false
INGEST_IDEMPOTENCY_TTL_HOURS=24

# Per-API-key rate limiting
INGEST_RATE_LIMIT_PER_KEY=100
ADMIN_API_KEY_EXEMPT=true

# CORS (optional extra allowed browser origins, comma-separated)
# Example: CORS_ORIGINS=https://clawinfra.up.railway.app
CORS_ORIGINS=

# Retention jobs (Phase 5)
RETENTION_ENABLED=true
RETENTION_SWEEP_INTERVAL_MINUTES=60
RETENTION_LOGS_DAYS=30
RETENTION_METRICS_RAW_DAYS=30
RETENTION_COSTS_DAYS=540
RETENTION_CODE_DAILY_DAYS=730

# Telegram Alerts — get from @BotFather and /getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenRouter Direct Sync
OPENROUTER_API_KEY=

# Database Connection Pool (optional)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=2000
