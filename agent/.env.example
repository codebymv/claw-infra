# ── claw-infra backend connection ──
# Use your backend's PUBLIC URL if internal hostname (backend, backend.railway.internal) fails to resolve.
# Example: https://backend-production-xxx.up.railway.app
BACKEND_INTERNAL_URL=https://your-backend.up.railway.app
AGENT_API_KEY=your-agent-api-key-from-dashboard

# ── ZeroClaw agent identity ──
ZEROCLAW_AGENT_NAME=zeroclaw-primary

# ── AI provider (OpenRouter recommended for multi-model) ──
ZEROCLAW_API_KEY=sk-or-v1-...
ZEROCLAW_PROVIDER=openrouter
ZEROCLAW_MODEL=anthropic/claude-sonnet-4-6

# ── Telegram channel (remote control from your phone) ──
ZEROCLAW_TELEGRAM_BOT_TOKEN=
# Comma-separated allowlist. Use your Telegram @username (without @) or numeric user id.
ZEROCLAW_TELEGRAM_ALLOWED_USERS=your_telegram_username

# ── Memory backend ──
# Prebuilt ZeroClaw binary only supports sqlite. Use sqlite for agent memory.
# (Dashboard uses Railway Postgres separately for runs/steps/costs.)
ZEROCLAW_MEMORY_BACKEND=sqlite
# DATABASE_URL only needed if ZEROCLAW_MEMORY_BACKEND=postgres (requires building ZeroClaw from source)

# ── GitHub access ──
# Required for the agent to clone repos, read private files, or call the GitHub API.
# Create a fine-grained personal access token at: https://github.com/settings/tokens
# Minimum scopes: Contents (read), Metadata (read). Add "read:org" for org repos.
# Either variable name works — GITHUB_TOKEN is the standard convention.
GITHUB_TOKEN=ghp_...
# ZEROCLAW_GITHUB_TOKEN=ghp_...   # alias, use one or the other

# ── Autonomy ──
ZEROCLAW_AUTONOMY=supervised
ZEROCLAW_ALLOWED_COMMANDS=git,npm,cargo,ls,cat,grep,curl

# ── Reporter tuning ──
METRICS_INTERVAL_MS=15000
LOG_BATCH_INTERVAL_MS=5000
